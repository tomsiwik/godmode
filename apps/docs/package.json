    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "nitro": "^3.0.260311-beta",
    "portless": "^0.4.1",
    "serve": "^14.2.6",
    "srvx": "^0.11.12",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1"
